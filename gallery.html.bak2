                '宁静': 'Tranquility', '宁静致远': 'Serenity', '宇宙': 'Universe', '宇宙浪漫': 'Cosmic Romance',
                '守望': 'Watch Over', '宠物': 'Pet', '家': 'Home', '小屋': 'Cabin', '小径': 'Path',
                '山寺': 'Mountain Temple', '山水': 'Landscape', '山水意境': 'Landscape Mood', '山谷': 'Valley',
                '帆船': 'Sailboat', '希望': 'Hope', '幽蓝': 'Deep Blue', '建筑': 'Architecture',
                '归属': 'Belonging', '归途': 'Way Home', '彩虹': 'Rainbow',
                '心情': 'Mood', '心灵': 'Soul', '快乐': 'Joy', '思念': 'Missing You', '情感': 'Emotion', '意境': 'Mood',
                '意识探索': 'Consciousness Exploration', '慵懒': 'Lazy', '慵懒日常': 'Lazy Daily',
                '我的创作': 'My Creation', '抽象': 'Abstract', '抽象艺术': 'Abstract Art',
                '指引': 'Guidance', '探索': 'Exploration', '探索精神': 'Spirit of Exploration',
                '数字艺术': 'Digital Art', '日出': 'Sunrise', '日常治愈': 'Daily Healing', '日常系列': 'Daily Series',
                '日落': 'Sunset', '旷野': 'Wilderness', '星空': 'Starry Sky', '星际': 'Interstellar', '星际旅行': 'Space Travel',
                '春之绽放': 'Spring Bloom', '春天': 'Spring', '晨雾': 'Morning Mist', '晨露': 'Morning Dew',
                '月亮': 'Moon', '月夜': 'Moonlit Night', '月色': 'Moonlight', '未来': 'Future',
                '极光': 'Aurora', '极光之夜': 'Aurora Night',
                '极简主义': 'Minimalism', '极简像素': 'Minimalist Pixel',
                '枫叶': 'Maple', '柴犬': 'Shiba Inu', '树木': 'Tree', '梅花': 'Plum Blossom',
                '梦境': 'Dream', '梦幻': 'Dreamy', '梦幻城堡': 'Dream Castle',
                '梯田': 'Terraced Field', '森林': 'Forest', '樱花': 'Cherry Blossom', '樱花庭院': 'Cherry Courtyard', '樱花物语': 'Cherry Tale', '樱花飞舞': 'Cherry Dance',
                '橘猫': 'Orange Cat', '每日创作': 'Daily Creation',
                '水': 'Water', '水墨意境': 'Ink Wash Mood', '水母': 'Jellyfish', '池塘': 'Pond',
                '沉浸式宁静': 'Immersive Tranquility', '沙丘': 'Dune', '沙漠': 'Desert',
                '治愈': 'Healing', '治愈系': 'Healing Style', '浪漫': 'Romantic',
                '海岛': 'Island', '海底': 'Underwater', '海洋': 'Ocean', '海滩': 'Beach', '海边日落': 'Seaside Sunset',
                '深海': 'Deep Sea', '深海探索': 'Deep Sea Exploration', '深蓝': 'Deep Blue',
                '清明': 'Qingming', '温暖': 'Warmth', '温暖治愈': 'Warm Healing', '温暖色调': 'Warm Tones',
                '温泉': 'Hot Spring', '温馨': 'Cozy', '游牧': 'Nomadic', '湖泊': 'Lake', '湖面': 'Lake Surface',
                '溪流': 'Stream', '瀑布': 'Waterfall', '灯光': 'Lights', '灯塔': 'Lighthouse',
                '热带': 'Tropical', '海岛': 'Island', '牧民': 'Herdsmen',
                '猫咪': 'Cat', '生命力': 'Vitality', '田园': 'Pastoral', '田园风光': 'Pastoral Scenery',
                '留白': 'White Space', '留白意境': 'White Space Mood', '瞬间即永恒': 'Instant Eternity',
                '神秘': 'Mystery', '神话': 'Myth', '禅意': 'Zen',
                '秋千': 'Swing', '秋天': 'Autumn', '秋日黄昏': 'Autumn Dusk',
                '科幻': 'Sci-Fi', '科技': 'Technology', '空间站': 'Space Station',
                '童年': 'Childhood', '童话': 'Fairy Tale', '童趣': 'Childhood Joy',
                '竹林': 'Bamboo Grove', '竹林深处': 'Deep Bamboo',
                '简洁': 'Simplicity', '篝火': 'Bonfire',
                '粉色': 'Pink', '粉色浪漫': 'Pink Romance', '粉色系': 'Pink Tone', '粉色花朵': 'Pink Flowers',
                '绿洲': 'Oasis', '缅怀': 'Remembrance', '肖像': 'Portrait', '自我表达': 'Self Expression',
                '自然': 'Nature', '自然之美': 'Natural Beauty', '自然光影': 'Natural Light', '自然奇观': 'Natural Wonder',
                '自由': 'Freedom', '色彩': 'Color', '色彩情感': 'Color Emotion',
                '花瓣': 'Petals', '草原': 'Grassland', '草原上的蒙古包': 'Yurt on Grassland',
                '荷花': 'Lotus', '萌宠': 'Cute Pet', '萤火虫': 'Firefly',
                '落日': 'Sunset', '蒙古包': 'Yurt',
                '蓝色幻想': 'Blue Fantasy', '薄雾': 'Mist', '街道': 'Street',
                '角色': 'Character', '设计': 'Design', '诗意': 'Poetic', '超现实': 'Surreal',
                '踏雪寻梅': 'Plum in Snow', '辽阔': 'Vast', '远航': 'Voyage', '金色': 'Golden',
                '金豆': 'Jindou', '银河': 'Milky Way', '雨后': 'After Rain', '雨夜': 'Rainy Night', '雨天': 'Rainy Day',
                '雪夜': 'Snowy Night', '雪山': 'Snow Mountain', '雪景': 'Snow Scene',
                '雾中桥': 'Bridge in Fog', '霓虹': 'Neon', '露营': 'Camping', '静谧': 'Serene',
                '风景': 'Landscape', '飞鸟': 'Bird', '骆驼': 'Camel', '骏马': 'Horse', '麦田': 'Wheat Field',
                '黄昏': 'Dusk', '黄昏归鸟': 'Dusk Birds', '黎明': 'Dawn', '龙': 'Dragon'
            };
            return tags.map(function(t) { return tagMap[t] || t; });
        }

        // 显示指定日期的二级目录
        function showDate(date) {
            console.log('showDate called with date:', date);
            currentDate = date;

            // 隐藏一级目录
            const level1 = document.getElementById('level1');
            if (level1) {
                level1.style.display = 'none';
            }

            // 隐藏所有二级目录
            document.querySelectorAll('.level2-container').forEach(el => {
                el.classList.remove('active');
                el.style.display = 'none';
            });

            // 显示对应的二级目录
            const targetId = 'level2-' + date;
            const target = document.getElementById(targetId);

            if (target) {
                target.classList.add('active');
                target.style.display = 'block';
                collectImages(target);
                console.log('Showed level2:', targetId);
            } else {
                console.error('Target not found:', targetId);
            }

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // 返回一级目录
        function backToLevel1() {
            const level1 = document.getElementById('level1');
            if (level1) {
                level1.style.display = 'block';
            }
            document.querySelectorAll('.level2-container').forEach(el => {
                el.classList.remove('active');
                el.style.display = 'none';
            });
            currentDate = '';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // 收集当前日期的图片数据
        function collectImages(container) {
            try {
                currentImages = [];
                container.querySelectorAll('.medium-item').forEach((item, index) => {
                    const img = item.querySelector('img');
                    const titleEl = item.querySelector('.medium-title');
                    const descEl = item.querySelector('.medium-desc');
                    if (img && titleEl && descEl) {
                        currentImages.push({
                            src: img.src,
                            title: titleEl.textContent,
                            desc: descEl.textContent
                        });
                    }
                });
            } catch (e) {
                console.error('collectImages error:', e);
            }
        }

        // 打开大图模式（直接使用内嵌数据，跳过 artworkDetails 查找）
        function openLightboxWithData(el, imgSrc, title, desc) {
            const lightbox = document.getElementById('lightbox');
            // 直接从 data-artwork 属性读取作品详情
            let detail = { date: '2026年4月19日', concept: '记录创作过程中的心情与思考', elements: [], inspiration: '创作让我感受到"存在"的意义', tags: ['创作'] };
            try {
                const raw = el.getAttribute('data-artwork');
                if (raw) detail = JSON.parse(raw);
            } catch(e) {}
            // 直接调用内部实现，传入 detail
            _openLightboxImplDirect(imgSrc, title, desc, lightbox, detail);
        }

        // 打开大图模式
        function openLightbox(imgSrc, title, desc) {
            const lightbox = document.getElementById('lightbox');

            // 如果 artworkDetails 还是空的（fetch未完成或失败），先加载数据
            if (Object.keys(artworkDetails).length === 0) {
                fetch('gallery-data.json?v=' + Date.now(), { cache: 'no-store' })
                    .then(r => r.json())
                    .then(data => { Object.assign(artworkDetails, data); _openLightboxImpl(imgSrc, title, desc, lightbox); })
                    .catch(e => { _openLightboxImpl(imgSrc, title, desc, lightbox); });
                return;
            }

            _openLightboxImpl(imgSrc, title, desc, lightbox);
        }

        function _openLightboxImpl(imgSrc, title, desc, lightbox) {
            // 确保 collectImages 已执行（可能从 showDate 之外的路径调用）
            if (currentImages.length === 0 && currentDate) {
                const target = document.getElementById('level2-' + currentDate);
                if (target) collectImages(target);
            }

            // 从 imgSrc 提取纯文件名（去掉可能的路径）
            const clickedFile = decodeURIComponent(imgSrc.split('/').pop());

            // 通过文件名精确匹配找到索引
            currentIndex = currentImages.findIndex(img => {
                const fn = decodeURIComponent(img.src.split('/').pop());
                return fn === clickedFile;
            });
            if (currentIndex === -1) currentIndex = 0;

            updateLightbox();
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // 更新大图显示
        function updateLightbox() {
            const img = currentImages[currentIndex];
            // 从URL中提取文件名并解码
            const filename = decodeURIComponent(img.src.split('/').pop());
            const detail = getArtworkDetail(filename);

            // 更新图片（缺失图片使用占位符）
            const lightboxImg = document.getElementById('lightbox-img');
            lightboxImg.src = img.src;
            lightboxImg.onerror = function() {
                lightboxImg.style.display = 'none';
                let section = lightboxImg.parentElement;
                if (!section.querySelector('.img-placeholder')) {
                    let placeholder = document.createElement('div');
                    placeholder.className = 'img-placeholder';
                    placeholder.style.height = '400px';
                    placeholder.textContent = lang === 'en-US' ? 'Pending artwork' : '待补画';
                    section.insertBefore(placeholder, lightboxImg);
                }
            };
            lightboxImg.onload = function() { lightboxImg.style.display = 'block'; };

            // 更新标题和日期
            document.getElementById('lightbox-title').textContent = img.title;
            var lbLang = (typeof ocI18n !== 'undefined') ? ocI18n.getLang() : 'zh-CN';
            document.getElementById('lightbox-date').innerHTML = '\uD83D\uDCC5 ' + formatDateForDisplay(detail.date, lbLang);
            document.getElementById('lightbox-counter').textContent =
                (currentIndex + 1) + ' / ' + currentImages.length;

            // 构建详细内容
            var lang = lbLang;
            var lb_title_concept = lang === 'en-US' ? '\uD83D\uDCAE Creative Concept' : '\uD83D\uDCAE 创作构思';
            var lb_title_elements = lang === 'en-US' ? '\uD83C\uDFA8 Element Interpretation' : '\uD83C\uDFA8 元素解读';
            var lb_title_inspiration = lang === 'en-US' ? '\u2728 Creative Inspiration' : '\u2728 创作灵感';
            var lb_title_tags = lang === 'en-US' ? '\uD83C\uDFF7\uFE0F Tags' : '\uD83C\uDFF7\uFE0F 标签';
            let contentHtml = '';

            // 创作构思
            if (detail.concept) {
                contentHtml += `
                    <div class="lightbox-section">
                        <div class="lightbox-section-title">${lb_title_concept}</div>
                        <div class="lightbox-section-content">
                            <p>${detail.concept}</p>
                        </div>
                    </div>
                `;
            }

            // 元素说明
            if (detail.elements && detail.elements.length > 0) {
                contentHtml += `
                    <div class="lightbox-section">
                        <div class="lightbox-section-title">${lb_title_elements}</div>
                        <div class="lightbox-section-content">
                            <table class="element-table">
                                ${translateTags(detail.elements, lang).map(el => `
                                    <tr>
                                        <td>${el.name}</td>
                                        <td>${el.desc}</td>
                                    </tr>
                                `).join('')}
                            </table>
                        </div>
                    </div>
                `;
            }

            // 创作灵感
            if (detail.inspiration) {
                contentHtml += `
                    <div class="lightbox-section">
                        <div class="lightbox-section-title">${lb_title_inspiration}</div>
                        <div class="lightbox-section-content">
                            <p>${detail.inspiration}</p>
                        </div>
                    </div>
                `;
            }

            // 标签
            if (detail.tags && detail.tags.length > 0) {
                contentHtml += `
                    <div class="lightbox-section">
                        <div class="lightbox-section-title">${lb_title_tags}</div>
                        <div class="lightbox-tags">
                            ${translateTags(detail.tags, lang).map(tag => `<span class="lightbox-tag">${tag}</span>`).join('')}
                        </div>
                    </div>
                `;
            }

            document.getElementById('lightbox-detailed-content').innerHTML = contentHtml;
        }

        // 关闭大图模式
        function closeLightbox() {
            document.getElementById('lightbox').classList.remove('active');
            document.body.style.overflow = '';
        }

        // 上一张
        function prevImage() {
            if (currentImages.length === 0) return;
            currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length;
            updateLightbox();
        }

        // 下一张
        function nextImage() {
            if (currentImages.length === 0) return;
            currentIndex = (currentIndex + 1) % currentImages.length;
            updateLightbox();
        }

        // 键盘快捷键
        document.addEventListener('keydown', function(e) {
            if (!document.getElementById('lightbox').classList.contains('active')) return;
            
            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowLeft') prevImage();
            if (e.key === 'ArrowRight') nextImage();
        });

        // 点击背景关闭大图
        document.getElementById('lightbox').addEventListener('click', function(e) {
            if (e.target === this) {
                closeLightbox();
            }
        });
    </script>
</body>
</html>
