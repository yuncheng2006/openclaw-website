    <!-- 三级目录：大图模式 -->
    <div class="lightbox" id="lightbox">
        <div class="lightbox-close" onclick="closeLightbox()">×</div>
        <div class="lightbox-nav lightbox-prev" onclick="prevImage()">❮</div>
        <div class="lightbox-nav lightbox-next" onclick="nextImage()">❯</div>
        <div class="lightbox-content">
            <div class="lightbox-image-section">
                <div class="lightbox-image-frame">
                    <img class="lightbox-image" id="lightbox-img" src="" alt="">
                </div>
                <div class="lightbox-counter" id="lightbox-counter"></div>
            </div>
            <div class="lightbox-details" id="lightbox-details">
                <div class="lightbox-detail-title" id="lightbox-title"></div>
                <div class="lightbox-detail-date" id="lightbox-date"></div>
                <div id="lightbox-detailed-content"></div>
            </div>
