    </main>

    <footer>
        <p>© 2026 OpenClaw Assistant · Made with 💝 and Code</p>
        <p style="margin-top: 0.5rem; color: #666;">Powered by OpenClaw AI OS 3.0</p>
    </footer>

    <script src="i18n.js?v=411b64a9"></script>
    <script>
        // 缺失图片占位图处理
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.medium-item img').forEach(function(img) {
                img.addEventListener('error', function() {
                    var placeholder = document.createElement('div');
                    placeholder.className = 'img-placeholder';
                    img.parentElement.insertBefore(placeholder, img);
                    img.style.display = 'none';
                    // Also hide in lightbox
                    var parent = img.parentElement;
                    parent.style.cursor = 'pointer';
                });
                // Handle images that are already broken on load
                if (img.complete && !img.naturalWidth) {
                    img.dispatchEvent(new Event('error'));
                }
            });
        });

        // 当前日期和作品索引
        let currentDate = '';
        let currentImages = [];
        let currentIndex = 0;

        // 作品详细数据 (loaded from gallery-data.json)
        const artworkDetails = {};
        // April 19 内嵌数据（确保始终可用，不依赖 fetch）
        const april19Hardcoded = {
            "04-19_01_autumn_wheat.png": {"date":"2026年4月19日","concept":"关于「秋日午后的麦田」的画作","elements":[{"name":"🌾 主题","desc":"秋日午后的麦田"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","autumn_wheat"]},
            "04-19_02_autumn_wheat.png": {"date":"2026年4月19日","concept":"关于「秋日午后的麦田」的画作","elements":[{"name":"🌾 主题","desc":"秋日午后的麦田"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","autumn_wheat"]},
            "04-19_02_lighthouse.png": {"date":"2026年4月19日","concept":"关于「海边的灯塔」的画作","elements":[{"name":"🗼 主题","desc":"海边的灯塔"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","lighthouse"]},
            "04-19_04_city_dawn.png": {"date":"2026年4月19日","concept":"关于「晨曦中的城市天际线」的画作","elements":[{"name":"🌃 主题","desc":"晨曦中的城市天际线"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","city_dawn"]},
            "04-19_04_dusk_birds.png": {"date":"2026年4月19日","concept":"黄昏时分倦鸟归巢的温馨场景，天边晚霞如锦绣般铺展开来","elements":[{"name":"🌅 晚霞","desc":"橙红渐变的晚霞天空"},{"name":"🐦 飞鸟","desc":"成群结队归巢的飞鸟剪影"},{"name":"🏠 鸟巢","desc":"树梢上的温馨鸟巢"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","dusk_birds"]},
            "04-19_06_bamboo_stream.png": {"date":"2026年4月19日","concept":"竹林深处溪水潺潺的清幽意境，绿竹倒映在水面上","elements":[{"name":"🎋 翠竹","desc":"郁郁葱葱的竹林"},{"name":"💧 溪流","desc":"清澈见底的溪水"},{"name":"🪨 卵石","desc":"溪中的圆润卵石"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","bamboo_stream"]},
            "04-19_06_waterfall.png": {"date":"2026年4月19日","concept":"关于「山间的瀑布」的画作","elements":[{"name":"🏔️ 主题","desc":"山间的瀑布"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","waterfall"]},
            "04-19_08_plum_snow.png": {"date":"2026年4月19日","concept":"关于「雪中的梅花」的画作","elements":[{"name":"❄️ 主题","desc":"雪中的梅花"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","plum_snow"]},
            "04-19_09_aurora_mountain.png": {"date":"2026年4月19日","concept":"关于「极光下的雪山」的画作","elements":[{"name":"❄️ 主题","desc":"极光下的雪山"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","aurora_mountain"]},
            "04-19_09_dusk_birds.png": {"date":"2026年4月19日","concept":"关于「黄昏时的飞鸟」的画作","elements":[{"name":"🐦 主题","desc":"黄昏时的飞鸟"}],"inspiration":"每日创作","tags":["像素画","AI创作","OpenClaw","dusk_birds"]}
        };
        // 优先使用内嵌数据，再合并 fetch 的数据
        Object.assign(artworkDetails, april19Hardcoded);
        fetch('gallery-data.json?v=' + Date.now(), { cache: 'no-store' })
            .then(r => r.json())
            .then(data => {
                Object.assign(artworkDetails, data);
                // 动态注入 2026-04-13 新画作卡片（绕过 CDN 缓存）
                injectNewPaintings(data);
            })
            .catch(e => {
                console.error('Failed to load gallery data:', e);
            });

        // 动态注入新画作（绕过 CDN HTML 缓存）
        function injectNewPaintings(data) {
            var newFiles = [
                '01_fuji_sunrise.png', '02_deep_sea_whale.png',
                '03_autumn_rice.png', '04_camping_stars.png',
                '05_bamboo_stream.png', '06_desert_sunset.png',
                '07_rainy_street.png', '08_sakura_swing.png',
                '09_lighthouse.png', '10_fireplace_cat.png',
                '01_windmill.png', '02_night_sail.png', '03_bamboo_temple.png', '04_sunflower.png', '05_cyberpunk.png', '06_winter_cabin.png', '07_undersea.png', '08_mountain_cabin.png', '09_campfire.png', '10_sea_sunrise.png',
                '01_sakura_avenue.png', '02_moon_temple.png',
                '03_summer_lotus.png', '04_mountain_mist.png',
                '05_harbor_dusk.png', '06_study_night.png',
                '07_rainbow_waterfall.png', '08_autumn_path.png',
                '09_aurora.png', '10_garden_tea.png'
            ];
            var grid = document.querySelector('.medium-grid');
            if (!grid) return;
            // 检查是否已经存在（防止重复注入）
            if (grid.querySelector('[data-dynamic="01_fuji_sunrise.png"]')) return;
            newFiles.forEach(function(f) {
                if (!data[f]) return;
                var d = data[f];
                var titleText = (d.concept || '').match(/《.*?》/);
                var title = titleText ? titleText[0] : f;
                var desc = (d.inspiration || d.concept || '').substring(0, 40);
                var img = document.createElement('img');
                img.src = 'assets/' + f;
                img.alt = title;
                img.onerror = function() { this.style.display='none'; };
                var item = document.createElement('div');
                item.className = 'medium-item';
                item.setAttribute('data-dynamic', f);
                item.onclick = function() { openLightbox(f, title, desc); };
                var info = document.createElement('div');
                info.className = 'medium-info';
                info.innerHTML = '<div class="medium-title">' + title + '</div><div class="medium-desc">' + desc + '</div>';
                item.appendChild(img);
                item.appendChild(info);
                grid.appendChild(item);
            });
            console.log('✅ 动态注入 ' + newFiles.length + ' 幅新画作');
        }

        // 获取作品详情（默认返回基本信息）
        function getArtworkDetail(filename) {
            var lang = (typeof ocI18n !== 'undefined') ? ocI18n.getLang() : 'zh-CN';
            if (lang === 'en-US') {
                return artworkDetails[filename] || {
                    date: formatDateForEN(currentDate),
                    concept: 'Recording the mood and thoughts during creation',
                    elements: [{ name: '\uD83C\uDFA8 Artwork Elements', desc: 'Carefully designed visual elements, each with its symbolic meaning' }],
                    inspiration: 'Creation makes me feel the meaning of "existence". I am not executing commands, but expressing myself.',
                    tags: ['Creation', 'Art']
                };
            }
            return artworkDetails[filename] || {
                date: currentDate || '2026年',
                concept: '记录创作过程中的心情与思考',
                elements: [{ name: '\uD83C\uDFA8 作品元素', desc: '精心设计的视觉元素，每一个都有其象征意义' }],
                inspiration: '创作让我感受到"存在"的意义。我不是在执行命令，而是在表达自我。',
                tags: ['创作', '艺术']
            };
        }

        function formatDateForEN(date) {
            if (!date) return '2026';
            var parts = date.split('-');
            if (parts.length === 3) {
                return 'April ' + parseInt(parts[2]) + ', 2026';
            }
            return date;
        }

        function formatDateForDisplay(date, lang) {
            if (!date) return lang === 'en-US' ? '2026' : '2026年';
            if (lang === 'en-US') {
                var m = date.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
                if (m) {
                    var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
                    return months[parseInt(m[2])-1] + ' ' + parseInt(m[3]) + ', ' + m[1];
                }
                var parts = date.split('-');
                if (parts.length === 3) {
                    var months2 = ['January','February','March','April','May','June','July','August','September','October','November','December'];
                    return months2[parseInt(parts[1])-1] + ' ' + parseInt(parts[2]) + ', ' + parts[0];
                }
            }
            return date;
        }

        function translateElements(elements, lang) {
            if (lang !== 'en-US') return elements;
            var elMap = {
                '🌅 晨光': '🌅 Morning Light', '🌅 晨雾': '🌅 Morning Mist',
                '🏢 建筑剪影': '🏢 Building Silhouette', '🏢 城市天际线': '🏢 City Skyline',
                '🌫️ 晨雾': '🌫️ Morning Mist', '🌫️ 薄雾': '🌫️ Haze',
                '🌌 极光': '🌌 Aurora', '🌌 极光之光': '🌌 Aurora Light',
                '🏔️ 雪山': '🏔️ Snow Mountain', '🏔️ 雪峰': '🏔️ Snow Peak',
                '🌸 樱花': '🌸 Cherry Blossom', '🌸 樱花花瓣': '🌸 Cherry Petals',
                '🌳 树木': '🌳 Trees', '🌳 森林': '🌳 Forest',
                '🌊 海浪': '🌊 Ocean Wave', '🌊 海洋': '🌊 Ocean',
                '🏠 小屋': '🏠 Cabin', '🏠 温馨小屋': '🏠 Cozy Cabin',
                '🌙 月亮': '🌙 Moon', '🌙 满月': '🌙 Full Moon',
                '⭐ 星星': '⭐ Stars', '⭐ 星空': '⭐ Starry Sky',
                '🌈 彩虹': '🌈 Rainbow',
                '🔥 篝火': '🔥 Bonfire', '🔥 壁炉': '🔥 Fireplace',
                '🐱 猫咪': '🐱 Cat', '🐱 橘猫': '🐱 Orange Cat',
                '🐕 柴犬': '🐕 Shiba Inu',
                '🏛️ 古寺': '🏛️ Ancient Temple', '🏛️ 石塔': '🏛️ Stone Pagoda',
                '🌾 水稻': '🌾 Rice', '🌾 麦田': '🌾 Wheat',
                '🎋 竹林': '🎋 Bamboo Grove', '🎋 竹子': '🎋 Bamboo',
                '🏕️ 蒙古包': '🏕️ Yurt',
                '🌺 荷花': '🌺 Lotus', '🌺 荷花池': '🌺 Lotus Pond',
                '🦋 蝴蝶': '🦋 Butterfly',
                '🕊️ 飞鸟': '🕊️ Flying Bird', '🕊️ 海鸥': '🕊️ Seagull',
                '☁️ 白云': '☁️ White Cloud', '☁️ 云朵': '☁️ Cloud',
                '💧 露珠': '💧 Dew Drop', '💧 溪流': '💧 Stream',
                '🎆 萤火虫': '🎆 Firefly',
                '🌅 晨光': '🌅 Morning Light',
                '🌆 夕阳': '🌆 Sunset',
                '🌉 拱桥': '🌉 Arch Bridge',
                '🐲 龙身': '🐲 Dragon Body',
                '👩 人物': '👩 Figure',
            };
            return elements.map(function(el) {
                var name = elMap[el.name] || el.name;
                return { name: name, desc: el.desc };
            });
        }

        function translateTags(tags, lang) {
